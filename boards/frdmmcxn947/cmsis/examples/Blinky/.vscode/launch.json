    "version": "0.2.0",
    "configurations": [
        {
            "name": "Core 0 (pyOCD)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${command:cmsis-csolution.getBinaryFile}",
            "gdb": "arm-none-eabi-gdb",
            "initCommands": [
                "load ./out/Blinky/FRDM-MCXN947/Debug/Blinky.hex",
                "break main"
            ],
            "target": {
                "server": "pyocd",
                "port": "3333"
            },
            "cmsis": {
                "cbuildRunFile": "FRDM-MCXN947.cbuild-run.yml"
            }
        }
    ]
}